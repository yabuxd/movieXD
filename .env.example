# TMDB API
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Netlify (either name works — set one in Site configuration → Environment variables)
# TMDB_API_KEY=your_tmdb_api_key_here

# Firebase Authentication
# Get these from: https://console.firebase.google.com
# Project Settings → Your apps → Web app → Firebase SDK snippet → Config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ── Firebase Console checklist ───────────────────────────────────────────────
# 1. Authentication → Sign-in method → enable Email/Password
# 2. Authentication → Sign-in method → enable Google
# 3. Authentication → Settings → Authorized domains → add:
#    - localhost
#    - movyxd.netlify.app (and your custom domain if any)
# 4. Authentication → Templates → customize verification email (optional)
# 5. Netlify → Environment variables → set all VITE_FIREBASE_* above, redeploy

# ── Google Cloud Console (for Sign in with Google) ───────────────────────────
# 1. APIs & Services → Credentials → OAuth 2.0 Client ID (Web application)
# 2. Authorized JavaScript origins:
#    - http://localhost:5173
#    - https://movyxd.netlify.app
# 3. Authorized redirect URIs (Firebase handles OAuth):
#    - https://your_project_id.firebaseapp.com/__/auth/handler

# TMDB API
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Netlify (either name works — set one in Site configuration → Environment variables)
# TMDB_API_KEY=your_tmdb_api_key_here

# Firebase (required for Google sign-in)
# Get these from your Firebase project: https://console.firebase.google.com
# Project Settings → Your apps → Web app → Firebase SDK snippet → Config
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
